projection;
strict ( 2 );

define behavior for ZKS_TRAVEL_PROCESSOR alias travel
{
  use create;
  use update;
  use delete;

  use association _booking { create; }
}

define behavior for ZKS_BOOKING_PROCESSOR alias Booking
{
  use update;
  use delete;

  use association _travel;
  use association _suppl { create; }
}

define behavior for ZKS_BOOKINGSUPPL_PROCESSOR alias BookSuppl
{
  use update;
  use delete;

  use association _travel;
  use association _booking;
}